# ---- Server ----
PORT=4000

# ---- Local MongoDB (MongoDB Compass / local mongod) ----
# Compass se connect karte ho wahi URI. Default local, koi auth nahi.
MONGO_URI=mongodb://127.0.0.1:27017/shree_yantra

# ---- VedAstro (PRIMARY astrology source; local astronomy-engine = automatic fallback) ----
# FREE tier = 15 requests/minute (no key). PAID = Unlimited (sk_live_... key).
# PAID karne ke liye: (1) key yahan daalo, (2) VEDASTRO_TIER=paid. env tier=paid hone par
# key har VedAstro call me lagti hai (DB Settings toggle ki zarurat nahi).
VEDASTRO_API_KEY=
# free | paid
VEDASTRO_TIER=free
# Ayanamsa — India standard = LAHIRI
VEDASTRO_AYANAMSA=LAHIRI

# ---- Claude AI (rashifal / chat) — pay-as-you-go, subscription NAHI. Abhi optional. ----
ANTHROPIC_API_KEY=

# ---- Auth (baad ke phase ke liye) ----
JWT_SECRET=change_me_to_a_long_random_string

# ---- Gemini AI ----
AI_PROVIDER=gemini
GEMINI_API_KEY=
# Extra Gemini keys (comma-separated) — auto-tried when the primary key's models
# hit their daily quota. Each key has its own quota, so more keys = more free AI.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# ---- OpenRouter — AUTOMATIC fallback jab Gemini quota/fail ho (FREE models, $0 balance) ----
# Key https://openrouter.ai se FREE milti hai (sk-or-v1-...), bina credit card ke.
# Service ke andar pura free-model chain (llama-3.3 / qwen3 / gpt-oss / gemma / hermes / nemotron)
# circuit-breaker ke saath try hota hai → AI kabhi down/slow feel nahi hota.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional: extra fallback models (CSV) — paid bhi daal sakte ho jab credits ho.
OPENROUTER_FALLBACK_MODELS=

# ---- Groq (very fast free LLM, OpenAI-compatible) — fallback between Gemini & OpenRouter ----
# Key https://console.groq.com se FREE milti hai. Models: llama-3.3-70b-versatile, llama-3.1-8b-instant.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- YouTube import/search for library media (optional; backend only) ----
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=IN

# ---- Admin dashboard ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
ADMIN_NAME=Admin
ADMIN_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Server ----
PORT=4000

# ---- Local MongoDB (MongoDB Compass / local mongod) ----
# Compass se connect karte ho wahi URI. Default local, koi auth nahi.
MONGO_URI=mongodb://127.0.0.1:27017/shree_yantra

# ---- VedAstro ----
# FREE tier ko API KEY ki ZARURAT NAHI (15 requests/minute).
# Jab $1/month plan kharido: (1) key yahan daalo, (2) dashboard se tier "paid" kar do.
VEDASTRO_API_KEY=
# Initial tier seed (free | paid). Runtime me dashboard toggle se badal sakte ho.
VEDASTRO_TIER=free
# Ayanamsa — India standard = LAHIRI
VEDASTRO_AYANAMSA=LAHIRI

# ---- Claude AI (rashifal / chat) — pay-as-you-go, subscription NAHI. Abhi optional. ----
ANTHROPIC_API_KEY=

# ---- Auth (baad ke phase ke liye) ----
JWT_SECRET=change_me_to_a_long_random_string

# ---- Gemini AI ----
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- YouTube import/search for library media (optional; backend only) ----
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=IN

# ---- Admin dashboard ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
ADMIN_NAME=Admin
ADMIN_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
